<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"

       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"

       xsi:schemaLocation="
http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id ="bean_id11" class ="dependency.Library">
        <property name = "id" value = "101"></property>
        <property name = "name" value = "Friends"></property>
        <property name = "book" ref="B1"></property>
    </bean>
    <bean id ="B1" class ="dependency.Book">
        <property name = "bookid" value = "101"></property>
        <property name = "bookname" value = "Friends"></property>
    </bean>
</beans>
